# Airflow Environment Configuration (Template)
# Copy this to airflow.env and fill in the secrets.
# Generate keys with: make fernet-key && make webserver-key && make jwt-secret-key

# ──────────────────────────────────────────────────────
# Airflow Core
# ──────────────────────────────────────────────────────
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/airflow
AIRFLOW__CORE__FERNET_KEY=your_generated_fernet_key_here

# ──────────────────────────────────────────────────────
# Webserver
# ──────────────────────────────────────────────────────
AIRFLOW__WEBSERVER__BASE_URL=http://localhost:8080
AIRFLOW__WEBSERVER__SECRET_KEY=your_generated_secret_key_here

# ──────────────────────────────────────────────────────
# API Auth (Execution API)
# ──────────────────────────────────────────────────────
# Synchronize this secret across all Airflow containers for token verification.
AIRFLOW__API_AUTH__JWT_SECRET=your_generated_jwt_secret_key_here

